# Copier ce fichier en .env pour les tests locaux
# Ne JAMAIS committer le fichier .env

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Supabase (https://supabase.com → Settings → API)
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_KEY=eyJhbGci...

# ntfy (ton topic perso, ex: mediaauto-hugo)
NTFY_TOPIC=mediaauto-hugo

# Newsletters par email (boîte dédiée, lue en IMAP chaque nuit)
# NEWSLETTER_PASSWORD = MOT DE PASSE D'APPLICATION (PAS le mot de passe du compte).
# Nécessite la validation en 2 étapes activée sur le compte.
#   Outlook : account.microsoft.com/security → Mots de passe d'application
#   Gmail   : myaccount.google.com → Sécurité → Mots de passe des applications
# NEWSLETTER_IMAP est OPTIONNEL : déduit du domaine (outlook/gmail/yahoo/icloud).
NEWSLETTER_EMAIL=
NEWSLETTER_PASSWORD=
# NEWSLETTER_IMAP=outlook.office365.com   # décommenter pour forcer un serveur

# Pexels (https://www.pexels.com/api/ → clé gratuite, 200 req/h)
# Utilisé pour les posts "Breaking News" (photo libre de droits + overlay titre)
# Sans cette clé, les posts breaking sont simplement ignorés.
PEXELS_API_KEY=

# X / Twitter Developer (https://developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Instagram (Meta for Developers → Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# LinkedIn (https://developer.linkedin.com)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=urn:li:person:XXXXXXX
